---
// Standalone landing page — no Starlight layout dependency.
// Astro user pages take priority over integration-injected routes,
// so this wins over Starlight's generated /index route.

const REGISTER_URL = 'https://editor.yokoi.app/register';
const LOGIN_URL    = 'https://editor.yokoi.app/login';
const EXPLORE_URL  = 'https://editor.yokoi.app/explore';
const DOCS_URL     = '/guides/mcp-server/';

const features = [
  {
    icon: 'edit_note',
    title: 'Manuscript Editor',
    desc: 'Write in Markdown with a distraction-free editor. Every save creates a new revision — your full history is always one click away.',
  },
  {
    icon: 'auto_stories',
    title: 'Story Bible',
    desc: 'Keep characters, locations, factions, items, and lore structured and linked to your chapters. Never lose track of your world.',
  },
  {
    icon: 'draw',
    title: 'Reader Feedback',
    desc: 'Readers annotate exact passages — anchored to character offsets and surviving future revisions with fuzzy re-matching.',
  },
  {
    icon: 'history',
    title: 'Revision History',
    desc: 'Full timeline of every chapter. Browse every change and compare any two revisions side by side.',
  },
  {
    icon: 'smart_toy',
    title: 'AI via MCP',
    desc: 'Connect Claude or any MCP-compatible assistant directly to your manuscripts. Create chapters, query your story bible, and more.',
  },
  {
    icon: 'book_2',
    title: 'OPDS Feed',
    desc: 'Read your library in KOReader, Calibre, Panels, or any OPDS-compatible app. Your books, always in sync.',
  },
];

const LOGO_SVG = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" width="28" height="28" aria-hidden="true">
  <rect width="32" height="32" rx="7" fill="#006b62"/>
  <path d="M7 6 L16 17 L25 6" stroke="white" stroke-width="3.2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
  <line x1="16" y1="17" x2="16" y2="27" stroke="white" stroke-width="3.2" stroke-linecap="round"/>
</svg>`;
---

<!doctype html>
<html lang="en">
  <head>
    <!-- FOUC prevention: must be first, before CSS -->
    <script is:inline>
      (function () {
        var stored = localStorage.getItem('yokoi-theme');
        var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (stored === 'dark' || (!stored && prefersDark)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Yokoi — Where stories are written, read, and remembered</title>
    <meta name="description" content="A platform for thoughtful writers and deliberate readers. Write manuscripts in Markdown, build a story bible, collect reader feedback, and publish your work." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:title" content="Yokoi" />
    <meta property="og:description" content="A platform for thoughtful writers and deliberate readers." />
    <meta property="og:type" content="website" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Newsreader:ital,wght@0,400;0,600;0,700;1,400;1,600&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" />

    <style is:global>
      /* ── Reset ─────────────────────────────────────────────── */
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html { scroll-behavior: smooth; }

      /* ── Design tokens ─────────────────────────────────────── */
      :root {
        --bg:                #f7f9fb;
        --fg:                #2a3439;
        --fg-muted:          #566166;
        --card:              #ffffff;
        --accent:            #006b62;
        --accent-dim:        #005e56;
        --on-accent:         #e2fff9;
        --primary:           #545f73;
        --primary-dim:       #485367;
        --on-primary:        #f6f7ff;
        --surface-low:       #f0f4f7;
        --surface-container: #e8eff3;
        --surface-highest:   #d9e4ea;
        --ghost-border:      rgba(169, 180, 185, 0.2);
        --outline:           #717c82;
        --radius:            0.375rem;
        --radius-lg:         0.75rem;

        --font-sans:  'Inter', ui-sans-serif, system-ui, sans-serif;
        --font-serif: 'Newsreader', Georgia, 'Times New Roman', serif;
      }

      :root.dark {
        --bg:                #111518;
        --fg:                #dce5e8;
        --fg-muted:          #8ba0a8;
        --card:              #1a2127;
        --accent:            #4db8ae;
        --accent-dim:        #3da89e;
        --on-accent:         #002f2b;
        --primary:           #6b7a94;
        --primary-dim:       #5c6a82;
        --on-primary:        #e8eaf6;
        --surface-low:       #151c20;
        --surface-container: #1a2329;
        --surface-highest:   #253038;
        --ghost-border:      rgba(100, 120, 130, 0.25);
        --outline:           #8ba0a8;
      }

      /* ── Base ──────────────────────────────────────────────── */
      body {
        font-family: var(--font-sans);
        font-size: 1rem;
        font-weight: 400;
        background: var(--bg);
        color: var(--fg);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        min-height: 100dvh;
      }

      /* ── Material Symbols ──────────────────────────────────── */
      .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;
        vertical-align: middle;
        line-height: 1;
      }

      /* ── Buttons ───────────────────────────────────────────── */
      .btn {
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
        padding: 0.5625rem 1.25rem;
        border-radius: var(--radius);
        font-family: var(--font-sans);
        font-size: 0.875rem;
        font-weight: 500;
        line-height: 1.4;
        text-decoration: none;
        border: none;
        cursor: pointer;
        white-space: nowrap;
        transition: opacity 0.15s, background 0.15s;
      }
      .btn-lg {
        padding: 0.75rem 1.625rem;
        font-size: 0.9375rem;
      }
      .btn-accent {
        background: linear-gradient(135deg, var(--accent) 0%, var(--accent-dim) 100%);
        color: var(--on-accent);
      }
      .btn-accent:hover { opacity: 0.88; }
      .btn-ghost {
        background: transparent;
        color: var(--fg);
        outline: 1px solid var(--ghost-border);
      }
      .btn-ghost:hover {
        background: var(--surface-container);
      }
      .btn-ghost-on-accent {
        background: transparent;
        color: var(--on-accent);
        outline: 1px solid rgba(255, 255, 255, 0.3);
      }
      .btn-ghost-on-accent:hover {
        background: rgba(255, 255, 255, 0.1);
      }

      /* ── Layout helpers ────────────────────────────────────── */
      .container {
        max-width: 80rem;
        margin-inline: auto;
        padding-inline: 1.5rem;
      }
      .section {
        padding-block: 5rem;
      }
    </style>
  </head>

  <body>
    <!-- ═══════════════════════════════════════════════════════ HEADER -->
    <header class="site-header">
      <div class="container header-inner">
        <a href="/" class="logo" aria-label="Yokoi home">
          <Fragment set:html={LOGO_SVG} />
          <span class="logo-text">Yokoi</span>
        </a>

        <nav class="header-nav" aria-label="Site navigation">
          <a href={DOCS_URL} class="nav-link">Documentation</a>
          <a href={EXPLORE_URL} class="nav-link">Explore</a>
        </nav>

        <div class="header-actions">
          <button id="theme-toggle" class="theme-btn" aria-label="Toggle theme">
            <span class="material-symbols-outlined" id="theme-icon">dark_mode</span>
          </button>
          <a href={LOGIN_URL} class="btn btn-ghost header-signin">Sign In</a>
          <a href={REGISTER_URL} class="btn btn-accent">Get Started</a>
        </div>
      </div>
    </header>

    <main>
      <!-- ═══════════════════════════════════════════════════ HERO -->
      <section class="hero-section">
        <div class="container hero-inner">
          <p class="eyebrow">A space for deliberate storytelling</p>

          <h1 class="hero-headline">
            Where stories are <span class="accent-word">written</span>,<br
            />read, and remembered.
          </h1>

          <p class="hero-tagline">
            Yokoi gives thoughtful writers and deliberate readers everything
            they need&thinsp;—&thinsp;from the first draft to the final
            annotation.
          </p>

          <div class="hero-cta">
            <a href={REGISTER_URL} class="btn btn-accent btn-lg">
              Start writing for free
              <span class="material-symbols-outlined btn-arrow">arrow_forward</span>
            </a>
            <a href={EXPLORE_URL} class="btn btn-ghost btn-lg">
              Explore the library
            </a>
          </div>
        </div>
      </section>

      <!-- ══════════════════════════════════════════════════ FEATURES -->
      <section class="section features-section">
        <div class="container">
          <div class="section-label">
            <span class="material-symbols-outlined section-label-icon">widgets</span>
            Everything you need
          </div>
          <h2 class="section-heading">
            Every tool a serious author needs,<br />nothing they don't.
          </h2>

          <div class="feature-grid">
            {features.map((f) => (
              <div class="feature-card">
                <span class="material-symbols-outlined feature-icon">{f.icon}</span>
                <h3 class="feature-title">{f.title}</h3>
                <p class="feature-desc">{f.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- ══════════════════════════════════════════════════════ CTA -->
      <section class="section cta-section">
        <div class="container">
          <div class="cta-card">
            <div class="cta-content">
              <p class="cta-eyebrow">Ready to begin?</p>
              <h2 class="cta-heading">Your story deserves the right home.</h2>
              <p class="cta-tagline">
                Join Yokoi and start building literary work that lasts&thinsp;—&thinsp;one
                chapter at a time.
              </p>
              <div class="cta-buttons">
                <a href={REGISTER_URL} class="btn btn-lg" style="background:#fff;color:#006b62;font-weight:600;">
                  Create a free account
                  <span class="material-symbols-outlined btn-arrow">arrow_forward</span>
                </a>
                <a href={LOGIN_URL} class="btn btn-ghost-on-accent btn-lg">
                  Sign in
                </a>
              </div>
            </div>

            <div class="cta-deco" aria-hidden="true">
              <svg viewBox="0 0 200 200" width="200" height="200" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="100" cy="100" r="80" stroke="rgba(255,255,255,0.12)" stroke-width="1.5"/>
                <circle cx="100" cy="100" r="55" stroke="rgba(255,255,255,0.08)" stroke-width="1.5"/>
                <circle cx="100" cy="100" r="30" stroke="rgba(255,255,255,0.06)" stroke-width="1.5"/>
                <path d="M60 50 L100 110 L140 50" stroke="rgba(255,255,255,0.3)" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                <line x1="100" y1="110" x2="100" y2="155" stroke="rgba(255,255,255,0.3)" stroke-width="4" stroke-linecap="round"/>
              </svg>
            </div>
          </div>
        </div>
      </section>
    </main>

    <!-- ════════════════════════════════════════════════════ FOOTER -->
    <footer class="site-footer">
      <div class="container footer-inner">
        <div class="footer-brand">
          <a href="/" class="logo" aria-label="Yokoi home">
            <Fragment set:html={LOGO_SVG} />
            <span class="logo-text">Yokoi</span>
          </a>
          <p class="footer-tagline">
            A space for the deliberate reader and the thoughtful writer.
          </p>
        </div>

        <nav class="footer-nav" aria-label="Footer navigation">
          <a href={DOCS_URL} class="footer-link">Documentation</a>
          <a href={EXPLORE_URL} class="footer-link">Explore</a>
          <a href={LOGIN_URL} class="footer-link">Sign In</a>
          <a href={REGISTER_URL} class="footer-link">Get Started</a>
        </nav>

        <p class="footer-copy">&copy; {new Date().getFullYear()} Yokoi</p>
      </div>
    </footer>

    <!-- Theme toggle logic -->
    <script is:inline>
      (function () {
        var btn = document.getElementById('theme-toggle');
        var icon = document.getElementById('theme-icon');

        function applyTheme(dark) {
          if (dark) {
            document.documentElement.classList.add('dark');
            if (icon) icon.textContent = 'light_mode';
          } else {
            document.documentElement.classList.remove('dark');
            if (icon) icon.textContent = 'dark_mode';
          }
        }

        // Sync icon with current state on load
        applyTheme(document.documentElement.classList.contains('dark'));

        if (btn) {
          btn.addEventListener('click', function () {
            var isDark = document.documentElement.classList.contains('dark');
            localStorage.setItem('yokoi-theme', isDark ? 'light' : 'dark');
            applyTheme(!isDark);
          });
        }
      })();
    </script>
  </body>
</html>

<style>
  /* ── Header ────────────────────────────────────────────────── */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 40;
    height: 3.5rem;
    border-bottom: 1px solid var(--ghost-border);
    background: color-mix(in srgb, var(--card) 85%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .header-inner {
    display: flex;
    align-items: center;
    height: 100%;
    gap: 0;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo-text {
    font-family: var(--font-serif);
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--fg);
    letter-spacing: -0.01em;
  }

  .header-nav {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-inline-start: 2rem;
  }

  .nav-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--fg-muted);
    text-decoration: none;
    transition: color 0.15s;
    white-space: nowrap;
  }

  .nav-link:hover { color: var(--fg); }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-inline-start: auto;
  }

  .theme-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    background: transparent;
    border: none;
    border-radius: var(--radius);
    color: var(--fg-muted);
    cursor: pointer;
    transition: color 0.15s, background 0.15s;
  }

  .theme-btn:hover {
    color: var(--fg);
    background: var(--surface-container);
  }

  @media (max-width: 40rem) {
    .header-nav,
    .header-signin { display: none; }
  }

  /* ── Hero ──────────────────────────────────────────────────── */
  .hero-section {
    padding-block: 7rem 5.5rem;
    /* Subtle radial gradient behind hero */
    background:
      radial-gradient(ellipse 80% 50% at 50% 0%, color-mix(in srgb, var(--accent) 8%, transparent) 0%, transparent 70%),
      var(--bg);
  }

  .hero-inner {
    text-align: center;
  }

  .eyebrow {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1.375rem;
  }

  .hero-headline {
    font-family: var(--font-serif);
    font-size: clamp(2.25rem, 5.5vw, 3.75rem);
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -0.025em;
    color: var(--fg);
    margin-bottom: 1.5rem;
  }

  .accent-word {
    color: var(--accent);
    font-style: italic;
  }

  .hero-tagline {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.125rem;
    color: var(--fg-muted);
    max-width: 36rem;
    margin-inline: auto;
    margin-bottom: 2.75rem;
    line-height: 1.75;
  }

  .hero-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .btn-arrow {
    font-size: 1.125rem;
    transition: transform 0.15s;
  }

  .btn:hover .btn-arrow {
    transform: translateX(2px);
  }

  /* ── Features ──────────────────────────────────────────────── */
  .features-section {
    background: var(--surface-low);
    border-top: 1px solid var(--ghost-border);
    border-bottom: 1px solid var(--ghost-border);
  }

  .section-label {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1.25rem;
  }

  .section-label-icon {
    font-size: 1rem;
    color: var(--accent);
  }

  .section-heading {
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.25;
    color: var(--fg);
    margin-bottom: 2.75rem;
  }

  .feature-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.875rem;
  }

  @media (min-width: 40rem) {
    .feature-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 64rem) {
    .feature-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .feature-card {
    background: var(--card);
    outline: 1px solid var(--ghost-border);
    border-radius: var(--radius);
    padding: 1.25rem;
    transition: outline-color 0.15s;
  }

  .feature-card:hover {
    outline-color: var(--accent);
  }

  .feature-icon {
    font-size: 1.375rem;
    color: var(--accent);
    display: block;
    margin-bottom: 0.75rem;
  }

  .feature-title {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--fg);
    margin-bottom: 0.375rem;
  }

  .feature-desc {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--fg-muted);
    line-height: 1.65;
  }

  /* ── CTA ───────────────────────────────────────────────────── */
  .cta-section {
    padding-block: 5rem;
  }

  .cta-card {
    background: linear-gradient(135deg, var(--accent) 0%, var(--accent-dim) 100%);
    border-radius: var(--radius-lg);
    padding: 3.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    overflow: hidden;
    position: relative;
  }

  .cta-content {
    max-width: 36rem;
    position: relative;
    z-index: 1;
  }

  .cta-eyebrow {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--on-accent);
    opacity: 0.75;
    margin-bottom: 0.75rem;
  }

  .cta-heading {
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: -0.02em;
    color: var(--on-accent);
    margin-bottom: 0.875rem;
  }

  .cta-tagline {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1rem;
    color: var(--on-accent);
    opacity: 0.8;
    line-height: 1.65;
    margin-bottom: 2rem;
  }

  .cta-buttons {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .cta-deco {
    position: absolute;
    right: 2rem;
    top: 50%;
    transform: translateY(-50%);
    opacity: 0.6;
    pointer-events: none;
  }

  @media (max-width: 48rem) {
    .cta-card { padding: 2.25rem 1.5rem; }
    .cta-deco { display: none; }
  }

  /* ── Footer ────────────────────────────────────────────────── */
  .site-footer {
    border-top: 1px solid var(--ghost-border);
    padding-block: 2.5rem;
    background: var(--bg);
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  @media (min-width: 48rem) {
    .footer-inner {
      flex-direction: row;
      align-items: center;
      gap: 2rem;
    }
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .footer-tagline {
    font-size: 0.8125rem;
    color: var(--fg-muted);
    max-width: 22rem;
    font-style: italic;
    font-family: var(--font-serif);
  }

  .footer-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 1.25rem;
    margin-inline-start: auto;
  }

  .footer-link {
    font-size: 0.8125rem;
    color: var(--fg-muted);
    text-decoration: none;
    transition: color 0.15s;
  }

  .footer-link:hover { color: var(--fg); }

  .footer-copy {
    font-size: 0.75rem;
    color: var(--outline);
    white-space: nowrap;
  }
</style>
